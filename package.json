{
    "name": "gommo-tick",
    "version": "1.0.0",
    "private": true,
    "main": "expo-router/entry",
    "scripts": {
        "start": "expo start --port 8090",
        "phone": "expo start --go --lan --port 8090",
        "phone:lan": "expo start --go --lan --port 8090",
        "phone:tunnel": "expo start --go --tunnel --port 8090",
        "phone:clear": "expo start --go --lan --port 8090 --clear",
        "phone:web": "expo start --web --host lan --port 8090",
        "phone:web:clear": "expo start --web --host lan --port 8090 --clear",
        "phone:usb:reverse": "\"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe\" reverse tcp:8090 tcp:8090",
        "android": "expo start --android --port 8090",
        "ios": "expo start --ios --port 8090",
        "web": "expo start --web --port 8090",
        "debug": "expo start --web --port 8090 --clear",
        "expo:start": "expo start --port 8090",
        "expo:web": "expo start --web --port 8090",
        "expo:android": "expo start --android --port 8090",
        "expo:ios": "expo start --ios --port 8090",
        "build": "expo export",
        "build:web": "expo export --platform web",
        "lint": "expo lint",
        "typecheck": "tsc --noEmit",
        "phone:tunnel:clear": "expo start --go --tunnel --port 8090 --clear",
        "phone:usb": "expo start --go --port 8090",
        "phone:usb:clear": "expo start --go --port 8090 --clear",
        "phone:usb:open": "\"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe\" shell am start -a android.intent.action.VIEW -d exp://127.0.0.1:8090/--/ host.exp.exponent",
        "phone:usb:connect": "npm run phone:usb:reverse && npm run phone:usb:open",
        "check:encoding": "node scripts/check-text-encoding.js"
    },
    "dependencies": {
        "@expo-google-fonts/inter": "0.4.2",
        "@expo/metro-runtime": "~57.0.3",
        "@hookform/resolvers": "5.4.0",
        "@shopify/flash-list": "2.0.2",
        "@tanstack/react-query": "5.101.2",
        "axios": "1.18.1",
        "expo": "^57.0.2",
        "expo-camera": "~57.0.0",
        "expo-constants": "~57.0.3",
        "expo-document-picker": "~57.0.0",
        "expo-font": "~57.0.0",
        "expo-haptics": "~57.0.0",
        "expo-image": "~57.0.0",
        "expo-linking": "~57.0.1",
        "expo-local-authentication": "~57.0.0",
        "expo-notifications": "~57.0.3",
        "expo-router": "~57.0.3",
        "expo-secure-store": "~57.0.0",
        "lucide-react-native": "1.23.0",
        "nativewind": "4.2.6",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "7.80.0",
        "react-native": "0.86.0",
        "react-native-css-interop": "0.2.6",
        "react-native-gesture-handler": "~2.32.0",
        "react-native-reanimated": "4.5.0",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "4.25.2",
        "react-native-svg": "15.15.4",
        "react-native-web": "0.21.2",
        "react-native-worklets": "0.10.0",
        "zod": "4.4.3",
        "zustand": "5.0.14"
    },
    "devDependencies": {
        "@babel/core": "7.29.7",
        "@expo/ngrok": "^4.1.0",
        "@types/react": "19.2.17",
        "eslint": "^9.0.0",
        "eslint-config-expo": "~57.0.0",
        "eslint-import-resolver-typescript": "4.4.5",
        "prettier": "3.9.4",
        "tailwindcss": "3.4.19",
        "typescript": "~6.0.3"
    }
}
