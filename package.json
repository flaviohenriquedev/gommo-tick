    "@types/react": "19.2.17",
    "eslint": "^9.0.0",
    "eslint-config-expo": "56.0.4",
    "eslint-import-resolver-typescript": "4.4.5",
    "prettier": "3.9.4",
    "tailwindcss": "3.4.19",
    "typescript": "~6.0.3"
  }
